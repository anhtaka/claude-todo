{
  "permissions": {
    "allow": [
      "Bash(npm create *)",
      "Bash(npm init *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:5173)",
      "Bash(open *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git -C * remote *)",
      "Bash(git -C * push *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git config --global *)"
    ]
  }
}
